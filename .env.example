# ── Supabase (bază de date + autentificare + storage poze) ──────────────────
# Le găsești în Supabase: Project Settings -> API
# Aceste două sunt publice (expuse în browser) — normal pentru cheia "anon".
VITE_SUPABASE_URL="https://xxxxxxxxxxxx.supabase.co"
VITE_SUPABASE_ANON_KEY="eyJ..."

# Cheia "service_role" — SECRETĂ, doar server-side (Vercel env var, NU în .env
# din front-end, fără prefix VITE_ ca să nu ajungă în bundle-ul de browser).
# O folosește api/contact.ts ca să scrie lead-uri fără să treacă prin RLS, și
# api/cloudinary-sign.ts ca să verifice că cel care cere upload e admin logat.
SUPABASE_SERVICE_ROLE_KEY="eyJ..."

# ── Cloudinary (stocare + optimizare poze) ───────────────────────────────────
# Din Cloudinary Dashboard -> Programmable Media -> Overview (sau Settings -> API Keys)
# Toate 3 rămân server-side (folosite doar în api/cloudinary-sign.ts) — API Secret
# NU trebuie niciodată expus în browser.
CLOUDINARY_CLOUD_NAME="numele-tau-cloudinary"
CLOUDINARY_API_KEY="123456789012345"
CLOUDINARY_API_SECRET="secretul-tau-cloudinary"

# ── Email tranzacțional (formular de contact) ────────────────────────────────
# Momentan: cont Gmail dedicat + "App Password" (Google Account -> Security ->
# 2-Step Verification -> App passwords). Necesită 2FA activat pe cont.
# Mai târziu, când e gata domeniul: se trece pe Zoho Mail schimbând doar
# valorile de mai jos (smtp.zoho.com, portul 465/587) — codul rămâne neschimbat.
EMAIL_HOST="smtp.gmail.com"
EMAIL_PORT="465"
EMAIL_USER="contact.aura.photography@gmail.com"
EMAIL_PASS="app-password-ul-generat-de-google"

# Adresa unde ajung notificările de cereri noi (Laurentiu)
ADMIN_NOTIFICATION_EMAIL="laurentiu@example.com"

